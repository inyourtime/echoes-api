{
  "name": "echoes-api",
  "version": "0.0.3",
  "description": "Backend API for the Echoes music life timeline platform.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --env-file=.env --watch src/index.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --experimental-test-module-mocks --test",
    "coverage": "npm run build && node --experimental-test-module-mocks --experimental-test-coverage --test",
    "start": "npm run build && node --env-file=.env dist/index.js",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "db:migrate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:dev": "drizzle-kit studio",
    "generate:openapi": "node --env-file=.env scripts/generate-openapi.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "25"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/oauth2": "^8.2.0",
    "@fastify/one-line-logger": "^2.1.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@scalar/fastify-api-reference": "^1.49.6",
    "close-with-grace": "^2.5.0",
    "drizzle-orm": "^1.0.0-beta.20",
    "env-schema": "^7.0.0",
    "fast-jwt": "^6.1.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "fastify-route-preset": "^1.0.1",
    "pg": "^8.20.0",
    "resend": "^6.9.4",
    "typebox": "^1.1.8",
    "ytmusic-api": "^5.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^1.0.0-beta.20",
    "typescript": "^6.0.2"
  }
}
