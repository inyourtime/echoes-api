{
  "name": "echoes-api",
  "version": "1.0.4",
  "description": "Backend API for the Echoes music life timeline platform.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --env-file=.env --watch src/index.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && npm run test:unit",
    "test:unit": "node --experimental-test-module-mocks --localstorage-file ./tests/.localstorage --test 'tests/**/*.test.ts'",
    "test:e2e": "npm run build && node --experimental-test-module-mocks --localstorage-file ./tests/.localstorage --test --test-concurrency=1 'e2e/**/*.test.ts'",
    "coverage": "npm run build && node --experimental-test-module-mocks --experimental-test-coverage --test",
    "start": "npm run build && node --env-file=.env dist/index.js",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "db:migrate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:dev": "drizzle-kit studio",
    "generate:openapi": "node --env-file=.env scripts/generate-openapi.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "25"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/oauth2": "^8.2.0",
    "@fastify/one-line-logger": "^2.1.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@scalar/fastify-api-reference": "^1.55.1",
    "close-with-grace": "^2.5.0",
    "drizzle-orm": "^1.0.0-rc.1",
    "env-schema": "^7.0.0",
    "fast-jwt": "^6.2.4",
    "fastify": "^5.8.5",
    "fastify-pg-boss": "^0.2.0",
    "fastify-plugin": "^5.1.0",
    "firebase-admin": "^13.8.0",
    "pg": "^8.20.0",
    "pg-boss": "^12.18.1",
    "resend": "^6.12.2",
    "typebox": "^1.1.36"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^1.0.0-rc.1",
    "msw": "^2.14.5",
    "typescript": "^6.0.3"
  }
}
